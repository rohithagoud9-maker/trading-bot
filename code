import logging
from binance.client import Client
from dotenv import load_dotenv
import os
# Used to securely store your API key in Colab
from google.colab import userdata

# Try loading from .env first (for local testing/non-Colab)
load_dotenv()

# Prefer Colab Secrets for API keys if available, fallback to .env
API_KEY = userdata.get('API_KEY')
if API_KEY is None:
    API_KEY = os.getenv('API_KEY')

API_SECRET = userdata.get('API_SECRET')
if API_SECRET is None:
    API_SECRET = os.getenv('API_SECRET')

# Check if API_KEY and API_SECRET are loaded
if not API_KEY or not API_SECRET:
    print("Error: API_KEY or API_SECRET not found. Please set them in Colab Secrets or a .env file.")
    exit()

# Binance Futures Testnet
client = Client(API_KEY, API_SECRET)
client.FUTURES_URL = "https://testnet.binancefuture.com/fapi"
logging.basicConfig(
    filename="trading_bot.log",
    level=logging.INFO,
    format="%(asctime)s - %(levelname)s - %(message)s"
)

symbol = input("Enter Symbol (Example: BTCUSDT): ").upper()
sid = input("Enter Side (BUY/SELL): ").upper()
order_type = input("Enter Order Type (MARKET/LIMIT): ").upper()

try:
    quantity = float(input("Enter Quantity: "))
except ValueError:
    print("Invalid quantity!")
    exit()

price = None
if order_type == "LIMIT":
    try:
        price = float(input("Enter Price: "))
    except ValueError:
        print("Invalid price!")
        exit()
try:
    if order_type == "MARKET":
        order = client.futures_create_order(
            symbol=symbol,
            side=sid,
            type="MARKET",
            quantity=quantity
        )

    elif order_type == "LIMIT":
        order = client.futures_create_order(
            symbol=symbol,
            side=sid,
            type="LIMIT",
            quantity=quantity,
            price=price,
            timeInForce="GTC"
        )

    else:
        print("Invalid Order Type!")
        exit()
    print("Order ID      :", order.get("orderId"))
    print("Status        :", order.get("status"))
    print("Executed Qty  :", order.get("executedQty"))
    print("Average Price :", order.get("avgPrice", "N/A"))

    logging.info(f"SUCCESS - {order}")

except Exception as e:
    print("\nOrder Failed!")
    print("Reason:", e)
    logging.error(str(e))

print("\nThank you for using the Trading Bot!")
